{
  "name": "familie-ef-soknad",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:dev-server && npm run set-node-options NODE_ENV=development BRUK_DEV_API=true ENV=localhost node server/build/server-lokal.js",
    "build": "npm run lint && npm run build:prod",
    "build:prod": "tsc --noEmit & vite build",
    "start": "npm run build:dev-server && npm run set-node-options NODE_ENV=development ENV=localhost node server/build/server-lokal.js",
    "start:mock": "npm run build:dev-server && npm run set-node-options NODE_ENV=development BRUK_MOCK_LOKALT=true ENV=localhost node server/build/server-lokal.js",
    "test": "vitest run",
    "vitest": "vitest",
    "lint": "tsc --project ./tsconfig.json --noEmit && eslint './src/**/*.{js,ts,tsx}'",
    "dev:hent-tokens": "npx tsx scripts/hent-dev-token.ts",
    "build:dev-server": "cd server && tsc --build --verbose && cd ..",
    "postinstall": "cd server && npm ci && cd ..",
    "set-node-options": "NODE_OPTIONS='--import=./server/build/register.js --es-module-specifier-resolution=node'"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@navikt/ds-css": "^8.7.0",
    "@navikt/ds-react": "^8.7.0",
    "@navikt/ds-tokens": "^8.2.2",
    "@navikt/fnrvalidator": "^2.2.0",
    "@navikt/land-verktoy": "^13.0.6",
    "@navikt/nav-dekoratoren-moduler": "^3.6.3",
    "@sentry/browser": "^10.44.0",
    "axios": "^1.15.0",
    "constate": "^3.3.3",
    "date-fns": "^4.1.0",
    "iso-datestring-validator": "^2.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-router-dom": "^7.13.1",
    "styled-components": "^6.3.11",
    "use-debounce": "^10.1.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "6.1.1",
    "http-proxy-middleware": "^3.0.5",
    "husky": "^9.1.7",
    "npm": "^11.11.1",
    "playwright": "^1.58.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "constate": {
      "react": "$react"
    },
    "react-day-picker": {
      "react": "$react"
    }
  }
}
