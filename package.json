{
  "name": "familie-ef-soknad",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:dev-server && npm run set-node-options NODE_ENV=development BRUK_DEV_API=true ENV=localhost node server/build/server-lokal.js",
    "build": "npm run lint && npm run build:prod",
    "build:prod": "tsc --noEmit & vite build",
    "start": "npm run build:dev-server && npm run set-node-options NODE_ENV=development ENV=localhost node server/build/server-lokal.js",
    "start:mock": "npm run build:dev-server && npm run set-node-options NODE_ENV=development BRUK_MOCK_LOKALT=true ENV=localhost node server/build/server-lokal.js",
    "test": "vitest run",
    "vitest": "vitest",
    "lint": "tsc --project ./tsconfig.json --noEmit && eslint './src/**/*.{js,ts,tsx}'",
    "dev:hent-tokens": "npx tsx scripts/hent-dev-token.ts",
    "build:dev-server": "cd server && tsc --build --verbose && cd ..",
    "postinstall": "cd server && npm ci && cd ..",
    "set-node-options": "NODE_OPTIONS='--import=./server/build/register.js --es-module-specifier-resolution=node'"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@navikt/ds-css": "^8.11.0",
    "@navikt/ds-react": "^8.11.0",
    "@navikt/ds-tokens": "^8.10.4",
    "@navikt/fnrvalidator": "^2.2.1",
    "@navikt/nav-dekoratoren-moduler": "^4.1.1",
    "@sentry/browser": "^10.54.0",
    "@sentry/react": "^10.54.0",
    "axios": "^1.16.1",
    "constate": "^4.0.0",
    "date-fns": "^4.3.0",
    "express-rate-limit": "^8.5.2",
    "iso-datestring-validator": "^2.2.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "react-router-dom": "^7.15.1",
    "styled-components": "^6.4.2",
    "use-debounce": "^10.1.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "http-proxy-middleware": "^4.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "npm": "^11.15.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "constate": {
      "react": "$react"
    },
    "react-day-picker": {
      "react": "$react"
    }
  }
}
